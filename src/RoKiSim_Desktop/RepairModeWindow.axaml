<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RoKiSim_Desktop.RepairModeWindow"
        Title="Jarvis - AI Tamir Asistanı" Width="640" Height="780"
        Background="#0d1117" WindowStartupLocation="CenterOwner">
    
    <Window.Styles>
        <Style Selector="Button:pointerover">
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="BorderBrush" Value="#30363d"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#8b5cf6"/>
        </Style>
    </Window.Styles>
    
    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="12">
        
        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" CornerRadius="10" Padding="14" Margin="0,0,0,8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#1e1b4b" Offset="0"/>
                    <GradientStop Color="#312e81" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="🔧" FontSize="26" VerticalAlignment="Center"/>
                    <StackPanel Spacing="0">
                        <TextBlock Text="Jarvis Tamir Modu" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Yapay Zeka Destekli Arıza Tespiti" FontSize="10" Foreground="#a5b4fc"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="2" x:Name="ClearChatBtn" Content="🗑️" Background="Transparent" Foreground="#94a3b8" FontSize="18" Padding="8,4" Margin="0,0,6,0" Click="OnClearChatClick" ToolTip.Tip="Sohbeti Temizle"/>
                <Button Grid.Column="3" x:Name="PhoneConnectBtn" Content="📱 Telefon Bağla" Background="#7c3aed" Foreground="White" CornerRadius="6" Padding="14,8" Click="OnPhoneConnectClick" FontWeight="Bold" FontSize="13"/>
            </Grid>
        </Border>

        <!-- ═══ PHONE BANNER ═══ -->
        <Border Grid.Row="1" x:Name="PhoneBanner" CornerRadius="8" Padding="12" Margin="0,0,0,8" IsVisible="False" BorderBrush="#7c3aed" BorderThickness="1">
            <Border.Background>
                <SolidColorBrush Color="#1e1b4b" Opacity="0.6"/>
            </Border.Background>
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="📱 Telefonundan bu adrese git:" Foreground="#c4b5fd" FontSize="12"/>
                    <SelectableTextBlock x:Name="PhoneUrlText" Text="http://..." Foreground="#a78bfa" FontSize="18" FontWeight="Bold" FontFamily="Consolas"/>
                    <TextBlock Text="Aynı WiFi ağında olmalısın" Foreground="#6366f1" FontSize="10" FontStyle="Italic"/>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="PhoneStatusDot" Text="🟢" FontSize="20" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- ═══ CHAT AREA ═══ -->
        <Border Grid.Row="2" CornerRadius="10" Margin="0,0,0,8" BorderBrush="#21262d" BorderThickness="1" ClipToBounds="True">
            <Grid>
                <ScrollViewer x:Name="ChatScrollViewer" Background="#161b22" Padding="10">
                    <StackPanel x:Name="ChatPanel" Spacing="8"/>
                </ScrollViewer>
                <!-- Thinking indicator overlay -->
                <Border x:Name="ThinkingIndicator" IsVisible="False" Background="#161b22" Height="40" VerticalAlignment="Bottom" Padding="12,8" Opacity="0.95">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="⏳" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ThinkingText" Text="Jarvis düşünüyor..." Foreground="#a78bfa" FontSize="13" FontStyle="Italic" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ IMAGE PREVIEW ═══ -->
        <Border Grid.Row="3" x:Name="ImagePreviewBorder" Background="#1c2128" CornerRadius="8" Padding="6" Margin="0,0,0,8" IsVisible="False" HorizontalAlignment="Left" BorderBrush="#30363d" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Image x:Name="PreviewImage" Height="80" Stretch="Uniform"/>
                <Button Content="✕" Background="#da3633" Foreground="White" FontSize="12" Padding="6,2" CornerRadius="4" Click="OnRemoveImageClick" VerticalAlignment="Top"/>
            </StackPanel>
        </Border>

        <!-- ═══ INPUT AREA ═══ -->
        <Border Grid.Row="4" Background="#161b22" CornerRadius="10" Padding="8" BorderBrush="#21262d" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Content="📷" Background="#238636" Foreground="White" CornerRadius="6" Padding="12,10" Margin="0,0,8,0" Click="OnUploadImageClick" FontSize="16" ToolTip.Tip="Bilgisayardan Fotoğraf Seç"/>
                
                <TextBox Grid.Column="1" x:Name="InputTextBox" Watermark="Sorunu anlat veya fotoğraf gönder..." CornerRadius="6" Padding="10" Background="#0d1117" Foreground="White" KeyDown="OnInputKeyDown" TextWrapping="Wrap" MaxHeight="80" FontSize="13"/>
                
                <Button Grid.Column="2" x:Name="SendButton" Content="➤" Background="#7c3aed" Foreground="White" CornerRadius="6" Padding="14,10" Margin="8,0,0,0" Click="OnSendClick" FontSize="18" FontWeight="Bold" ToolTip.Tip="Gönder"/>
            </Grid>
        </Border>

        <!-- ═══ LOGIN OVERLAY ═══ -->
        <Border x:Name="LoginOverlay" Grid.Row="0" Grid.RowSpan="5" Background="#e60d1117" IsVisible="True" CornerRadius="10">
            <Border Background="#161b22" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
                <StackPanel Spacing="20">
                    <TextBlock Text="🔧 Sistem Bağlantısı" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Lütfen Jarvis ağa bağlanmak için kimliğinizi doğrulayın." FontSize="13" Foreground="#a5b4fc" TextWrapping="Wrap" TextAlignment="Center"/>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Mühendis Adı" Foreground="#8b949e" FontSize="12" FontWeight="Bold"/>
                        <TextBox x:Name="LoginNameTextBox" Watermark="Adınız ve Soyadınız" FontSize="14" Padding="10"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Gemini API Anahtarı" Foreground="#8b949e" FontSize="12" FontWeight="Bold"/>
                        <TextBox x:Name="LoginApiKeyTextBox" Watermark="AI-1234567..." PasswordChar="•" FontSize="14" Padding="10"/>
                        <TextBlock Text="Güvenli bağlantı. Anahtarınız sadece yerel cihazınızda şifresiz saklanır." FontSize="10" Foreground="#6e7681"/>
                    </StackPanel>
                    
                    <Button Content="Sisteme Giriş Yap" Background="#7c3aed" Foreground="White" CornerRadius="6" Padding="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="15" FontWeight="Bold" Click="OnLoginClick"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
